generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  name            String
  pixKeyHash      String   @unique // Hash determinístico para busca/login
  pixKeyEncrypted String   // Valor real criptografado (AES-256)
  city            String
  pin             String   // Hash do PIN de 6 dígitos
  createdAt       DateTime @default(now())
  bills           Bill[]
}

model Bill {
  id          String   @id @default(cuid())
  amount      Float
  peopleCount Int
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  scanCount   Int      @default(0)
  paidCount   Int      @default(0)
  createdAt   DateTime @default(now())
}
